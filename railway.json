{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run render:build"
  },
  "deploy": {
    "startCommand": "npm run render:start",
    "healthcheckPath": "/api/status",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
