// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  sessionId String   @unique // The WhatsApp session ID used by Baileys
  name      String   // Display name
  status    String   @default("DISCONNECTED") // CONNECTED, DISCONNECTED, CONNECTING
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Flows     Flow[]   // Flows attached to this session
}

model Flow {
  id          String   @id @default(uuid())
  name        String
  description String?
  nodes       String   // JSON string of React Flow nodes
  edges       String   // JSON string of React Flow edges
  isActive    Boolean  @default(false)
  sessionId   String?
  Session     Session? @relation(fields: [sessionId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Executions  Execution[]
}

model Execution {
  id        String   @id @default(uuid())
  flowId    String
  Flow      Flow     @relation(fields: [flowId], references: [id])
  status    String   // PENDING, RUNNING, COMPLETED, FAILED
  logs      String   // JSON string of execution steps/logs
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id          String   @id @default(uuid())
  name        String
  description String?
  provider    String   @default("openai")
  model       String   @default("gpt-4o")
  systemPrompt String  @default("You are a helpful WhatsApp assistant.")
  temperature Float    @default(0.7)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  remoteJid String
  messageId String
  sender    String?
  text      String?
  timestamp Int
  createdAt DateTime @default(now())
}

model Broadcast {
  id         String   @id @default(uuid())
  name       String
  sessionId  String?
  recipients String   // JSON array of WhatsApp JIDs
  text       String
  status     String   @default("DRAFT") // DRAFT, RUNNING, COMPLETED, FAILED
  result     String?  // JSON execution result
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model FileAsset {
  id        String   @id @default(uuid())
  originalName String
  filename  String
  mimeType  String
  size      Int
  path      String
  createdAt DateTime @default(now())
}

model Variable {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  config      String?  // JSON string of plugin-specific configs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
