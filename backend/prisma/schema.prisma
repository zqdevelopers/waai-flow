generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  sessionId String   @unique
  name      String
  status    String   @default("DISCONNECTED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  Flows     Flow[]
}

model Flow {
  id          String      @id @default(uuid())
  name        String
  description String?
  nodes       String
  edges       String
  isActive    Boolean     @default(false)
  sessionId   String?
  Session     Session?    @relation(fields: [sessionId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  Executions  Execution[]
}

model Execution {
  id        String   @id @default(uuid())
  flowId    String
  Flow      Flow     @relation(fields: [flowId], references: [id])
  status    String
  logs      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Agent {
  id           String   @id @default(uuid())
  name         String
  description  String?
  provider     String   @default("openai")
  model        String   @default("gpt-4o")
  systemPrompt String   @default("You are a helpful WhatsApp assistant.")
  temperature  Float    @default(0.7)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Message {
  id        String   @id @default(uuid())
  remoteJid String
  messageId String
  sender    String?
  text      String?
  timestamp Int
  createdAt DateTime @default(now())
}

model Broadcast {
  id          String   @id @default(uuid())
  name        String
  sessionId   String?
  recipients  String
  messageType String   @default("text")
  text        String   @default("")
  messageData String?
  delayMs     Int      @default(1000)
  status      String   @default("DRAFT")
  result      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FileAsset {
  id           String   @id @default(uuid())
  originalName String
  filename     String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())
}

model Variable {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plugin {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
